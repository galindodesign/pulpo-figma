{
  "name": "growthlab-flow-builder",
  "version": "1.0.0",
  "description": "Pulpo — Figma plugin to design and document experiment flows on the canvas",
  "main": "code.js",
  "scripts": {
    "generate:tokens": "node scripts/generate-design-tokens.mjs",
    "generate:brand-icons": "node scripts/generate-brand-icons.mjs",
    "generate:brand-logo": "node scripts/generate-brand-logo.mjs",
    "generate:site-urls": "node scripts/inject-site-urls.mjs",
    "build": "npm run generate:tokens && npm run generate:brand-icons && npm run generate:brand-logo && node esbuild.config.js && npm run postbuild",
    "postbuild": "mkdir -p build/fonts build/assets && cp design-tokens.css build/design-tokens.css && cp ui.css build/ui.css && npm run generate:site-urls && cp fonts/*.woff2 build/fonts/ && cp assets/*.png build/assets/",
    "build:dev": "mkdir -p build-dev && cp ui.dev.html build-dev/ui.dev.html && node scripts/generate-dev-manifest.mjs && node scripts/inject-sync-config.mjs",
    "build:tsc": "tsc -p tsconfig.json",
    "lint": "eslint --ext .ts --ignore-pattern node_modules .",
    "lint:fix": "eslint --ext .ts --ignore-pattern node_modules --fix .",
    "watch": "npm run build -- --watch",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "author": "",
  "license": "",
  "devDependencies": {
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "^1.121.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.27.1",
    "eslint": "^8.54.0",
    "sortablejs": "^1.15.7",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4"
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:@figma/figma-plugins/recommended"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "project": "./tsconfig.json"
    },
    "root": true,
    "rules": {
      "@typescript-eslint/no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_",
          "caughtErrorsIgnorePattern": "^_"
        }
      ]
    }
  }
}
